# ─────────────────────────────────────────────────────────────────
# IGSS Fondo Rotativo — Variables de entorno
# Copia este archivo como .env.local y rellena los valores
# NUNCA subas .env.local a Git
# ─────────────────────────────────────────────────────────────────

# Neon PostgreSQL — obtén la URL desde console.neon.tech
# Formato: postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# NextAuth — genera con: openssl rand -base64 32
AUTH_SECRET="CAMBIA_ESTO_POR_UNA_CLAVE_SEGURA_DE_32_CARACTERES"

# URL del sitio (en Vercel se setea automático, aquí para desarrollo)
NEXTAUTH_URL="http://localhost:3000"
